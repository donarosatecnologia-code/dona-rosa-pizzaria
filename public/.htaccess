# Dona Rosa Pizzaria — SPA fallback (Apache / HostGator / cPanel)
# Sem este arquivo, /login, /admin e /politica-de-privacidade retornam 404.

Options -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # index.html direto — não reescrever de novo
  RewriteRule ^index\.html$ - [L]

  # Arquivo, pasta ou link simbólico real → servir direto
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l

  # Demais rotas → React Router
  RewriteRule ^ /index.html [L,QSA]
</IfModule>

# Evita listagem de diretórios (HostGator costuma permitir no .htaccess)
<IfModule mod_autoindex.c>
  Options -Indexes
</IfModule>

# Cache para assets com hash (Vite)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>
