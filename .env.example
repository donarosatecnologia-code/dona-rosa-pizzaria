# Copie para .env e preencha (nunca commite o .env)

# URL canônica do site em produção (SEO / Open Graph / JSON-LD / e-mails de auth)
# HostGator (produção atual): https://donarosapizzaria.com.br
# Vercel (backup): use a URL do projeto na Vercel
# VITE_PUBLIC_SITE_URL=https://donarosapizzaria.com.br

# Supabase (projeto no painel: Settings > API)
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=sua-chave-anon-publica

# Embedded Signup Meta (público — vai no build Vite)
# VITE_META_APP_ID=912159588512848
# VITE_META_EMBEDDED_SIGNUP_CONFIG_ID=cole_o_configuration_id_aqui
# VITE_META_BUSINESS_ID=opcional — ID do portfólio Dona Rosa (URL business.facebook.com/settings ?business_id=)
# VITE_META_ALLOW_EMBEDDED_SIGNUP_POPUP=true  # liga botão que mostra QR no monitor para Rosa escanear

# ---------------------------------------------------------------------------
# WhatsApp Business / Disparos Ativos — NÃO coloque no .env do Vite
# Configure apenas como Supabase Secrets (Edge Functions):
#
#   supabase secrets set META_APP_SECRET=...
#   supabase secrets set META_ACCESS_TOKEN=...
#   supabase secrets set META_PHONE_NUMBER_ID=...
#   supabase secrets set META_VERIFY_TOKEN=...
#
# META_APP_SECRET        → validação HMAC do webhook (X-Hub-Signature-256)
# META_ACCESS_TOKEN      → envio via Graph API (motor de disparo)
# META_PHONE_NUMBER_ID   → ID do número WhatsApp Business (não confundir com WABA ID)
# META_WABA_ID           → ID da conta WhatsApp Business (opcional; cobrança / painel Meta)
# META_VERIFY_TOKEN      → token de verificação GET do webhook Meta
# META_API_VERSION       → versão Graph API (opcional, default v21.0)
# BROADCAST_DRY_RUN      → true simula envio; false envia de verdade (go-live)
#
# Opt-in do site (formulário/widget): Edge Function register-site-consent
# (não usa RPC pública no Postgres — ver docs/SEGURANCA-AUTH.md)
# ---------------------------------------------------------------------------
