# Copie para supabase/secrets.meta.env e preencha (nunca commite)
# cp supabase/secrets.meta.env.example supabase/secrets.meta.env
#
# Onde obter cada valor (Meta Developers → seu App → WhatsApp):
#   META_APP_SECRET        → App Settings → Basic → App Secret
#   META_ACCESS_TOKEN      → WhatsApp → API Setup → "Temporary access token"
#                          (string LONGA iniciando com EAA… — NÃO é "Token de cliente" em Avançado)
#                          Token do portfólio DONA ROSA (Usuário do sistema). Após mover app: gere NOVO (erro 190).
#   META_PHONE_NUMBER_ID   → Gerenciador WhatsApp → Telefones → [seu número] →
#                          "Identificação do número de telefone" (NÃO é o WABA ID)
#                          Produção Dona Rosa (+55 11 93061-7116): 115847421431608
#                          Número de teste Meta (+1 555…): outro ID — não use em produção
#   META_WABA_ID           → Cobrança / Contas do WhatsApp Business → ID da conta
#                          Produção "Dona Rosa Pizzaria": 120100661027939
#                          Teste "Test WhatsApp Business Account": 1090381263501254
#   META_VERIFY_TOKEN      → string que você define (mesmo valor no webhook Meta)
#   META_API_VERSION       → ex: v21.0 (opcional, default v21.0)

META_APP_SECRET=
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=
# Simula disparos sem chamar Meta (true em dev; false no go-live com número BR)
BROADCAST_DRY_RUN=true
